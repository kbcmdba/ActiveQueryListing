#!/usr/bin/env bash
#
# AQL pre-commit hook
#
# Runs PHP syntax checks on staged .php files, then runs the full PHPUnit
# test suite. Blocks the commit if anything fails.
#
# Install with: git config core.hooksPath .githooks
# (or run scripts/install-hooks.sh)
#

set -euo pipefail

# Colors for nicer output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# 1. PHP syntax check on staged .php files
staged_php_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)
if [[ -n "$staged_php_files" ]]; then
    echo -e "${YELLOW}pre-commit: checking PHP syntax on staged files...${NC}"
    syntax_failed=0
    while IFS= read -r file; do
        if ! php -l "$file" > /dev/null 2>&1; then
            echo -e "${RED}  SYNTAX ERROR in $file${NC}"
            php -l "$file"
            syntax_failed=1
        fi
    done <<< "$staged_php_files"
    if [[ $syntax_failed -eq 1 ]]; then
        echo -e "${RED}pre-commit: PHP syntax errors found. Fix them and try again.${NC}"
        exit 1
    fi
    echo -e "${GREEN}pre-commit: PHP syntax OK${NC}"
fi

# 2. Run PHPUnit if it's available
if [[ -x vendor/bin/phpunit ]]; then
    echo -e "${YELLOW}pre-commit: running PHPUnit...${NC}"
    if ! vendor/bin/phpunit --no-coverage; then
        echo ""
        echo -e "${RED}pre-commit: tests failed. Fix them and try again.${NC}"
        echo -e "${YELLOW}pre-commit: to bypass (not recommended), use: git commit --no-verify${NC}"
        exit 1
    fi
    echo -e "${GREEN}pre-commit: all tests pass${NC}"
else
    echo -e "${YELLOW}pre-commit: vendor/bin/phpunit not found, skipping tests${NC}"
    echo -e "${YELLOW}pre-commit: run 'composer install' to enable test checks${NC}"
fi

exit 0

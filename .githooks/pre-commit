#!/usr/bin/env bash
#
# AQL pre-commit hook (advisory - never blocks commits)
#
# Runs PHP syntax checks on staged .php files, then runs the full PHPUnit
# test suite. Reports any failures LOUDLY but always lets the commit through.
#
# Rationale: when debugging or in the middle of a session, you most want to
# commit work-in-progress state - even if it's broken. Blocking commits risks
# losing code to power loss, distraction, or accidental file deletion. Failing
# tests are also valuable historical data when chasing bugs - they show
# exactly when something started going wrong.
#
# So: report problems, complain loudly, but never refuse the commit.
#
# Install with: git config core.hooksPath .githooks
# (or run scripts/install-hooks.sh)
#

# NOTE: do NOT use 'set -e' here - we want the script to keep running and
# always exit 0 at the end, even if individual checks fail.

# Colors for nicer output (avoid yellow-on-green contrast issues)
RED='\033[1;31m'
GREEN='\033[1;32m'
BOLD='\033[1;37m'
NC='\033[0m' # No Color

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root" || exit 0

problems_found=0

# 1. PHP syntax check on staged .php files
staged_php_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)
if [[ -n "$staged_php_files" ]]; then
    echo -e "${BOLD}pre-commit: checking PHP syntax on staged files...${NC}"
    while IFS= read -r file; do
        if ! php -l "$file" > /dev/null 2>&1; then
            echo -e "${RED}  ⚠ SYNTAX ERROR in $file${NC}"
            php -l "$file"
            problems_found=1
        fi
    done <<< "$staged_php_files"
    if [[ $problems_found -eq 0 ]]; then
        echo -e "${GREEN}pre-commit: PHP syntax OK${NC}"
    fi
fi

# 2. Run PHPUnit if it's available
if [[ -x vendor/bin/phpunit ]]; then
    echo -e "${BOLD}pre-commit: running PHPUnit...${NC}"
    if ! vendor/bin/phpunit --no-coverage; then
        echo ""
        echo -e "${RED}⚠ pre-commit: TESTS FAILED ⚠${NC}"
        echo -e "${BOLD}pre-commit: commit will proceed anyway (advisory mode)${NC}"
        echo -e "${BOLD}pre-commit: but you should fix these soon${NC}"
        problems_found=1
    else
        echo -e "${GREEN}pre-commit: all tests pass${NC}"
    fi
else
    echo -e "${BOLD}pre-commit: vendor/bin/phpunit not found, skipping tests${NC}"
    echo -e "${BOLD}pre-commit: run 'composer install' to enable test checks${NC}"
fi

if [[ $problems_found -eq 1 ]]; then
    echo ""
    echo -e "${RED}╔════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  Committing despite problems above (advisory). ║${NC}"
    echo -e "${RED}║  Don't forget to fix them!                     ║${NC}"
    echo -e "${RED}╚════════════════════════════════════════════════╝${NC}"
fi

# Always succeed - never block the commit
exit 0

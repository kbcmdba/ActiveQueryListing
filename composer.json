{
    "name" : "kbcmdba/aql",
    "description" : "Active Query Listing (MySQL)",
    "homepage" : "http://github.com/kbcmdba/ActiveQueryListing",
    "type" : "project",
    "license" : "GPL 2",
    "authors" : [
        {
            "name" : "KB Benton",
            "email" : "kbcmdba@gmail.com"
        }
    ],
    "require" : {
        "php" : ">=7.2"
    },
    "require-dev" : {
        "phpunit/phpunit" : "^11.0"
    },
    "suggest" : {
        "ext-redis" : "For Redis-based blocking cache (recommended for better performance)"
    },
	"autoload" : {
		"psr-4" : {
			"com\\kbcmdba\\aql\\Libs\\" : "Libs/"
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"com\\kbcmdba\\aql\\Tests\\" : "tests/"
		}
	},
	"config" : {
		"vendor-dir" : "vendor"
	},
	"scripts" : {
		"clean" : "rm -fr build",
		"test" : "phpunit",
		"test-coverage" : "XDEBUG_MODE=coverage phpunit --coverage-text --coverage-html=build/coverage"
	},
	"minimum-stability" : "alpha"
}

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE config SYSTEM "aql_config.dtd">
<!--
    AQL Configuration File (New Grouped Format)

    Copy this file to aql_config.xml and edit to match your environment.
    The config file should be readable only by the web server to protect credentials.

    Legacy flat <param> format is still supported for backward compatibility.
    See config_sample_legacy.xml for the old format.
-->
<config version="2">
    <!-- ================================================================== -->
    <!-- Configuration Database                                             -->
    <!-- AQL's own database where host list, groups, and settings are stored -->
    <!-- This is the ONLY host defined in config - all monitored hosts are  -->
    <!-- managed via manageData.php and stored in the host table.           -->
    <!-- ================================================================== -->
    <configdb type="mysql"
              host="127.0.0.1"
              port="3306"
              name="aql_db" />
    <!-- For MS-SQL, add instanceName attribute:                            -->
    <!-- <configdb type="mssql" host="..." port="1433" name="aql_db"       -->
    <!--           instanceName="SQLEXPRESS" />                             -->

    <!-- ================================================================== -->
    <!-- Credentials                                                        -->
    <!-- admin: connects to the configdb above                              -->
    <!-- monitor: default for all monitored hosts (override per-dbtype)     -->
    <!-- ================================================================== -->
    <user type="admin" name="aql_app" password="SomethingComplicated" />
    <user type="monitor" name="aql_mon" password="SomethingComplicated" />

    <!-- ================================================================== -->
    <!-- Monitoring Behavior                                                -->
    <!-- ================================================================== -->
    <monitoring baseUrl="https://localhost.localdomain/ActiveQueryListing/AJAXgetaql.php"
                timeZone="America/Chicago"
                minRefresh="15"
                defaultRefresh="60"
                issueTrackerBaseUrl="https://somewhere.jira.com/"
                roQueryPart="@@global.read_only OR @@global.innodb_read_only"
                killStatement="kill :pid"
                showSlaveStatement="show all slaves status"
                globalStatusDb="performance_schema" />
    <!-- roQueryPart: SQL expression to detect read-only servers             -->
    <!-- killStatement: Use "CALL mysql.rds_kill( :pid )" for AWS RDS       -->
    <!-- globalStatusDb: "performance_schema" for MySQL, "information_schema" for MariaDB -->

    <!-- ================================================================== -->
    <!-- Authentication                                                     -->
    <!-- LDAP and adminPassword are mutually exclusive:                     -->
    <!--   LDAP enabled  = authenticate via Active Directory                -->
    <!--   LDAP disabled = authenticate via adminPassword (any user accepted) -->
    <!-- ================================================================== -->
    <authentication adminPassword="changeme" />

    <ldap enabled="true"
          host="ldaps://ad.mycompany.com/"
          domainName="DC=mycompany,DC=com"
          userGroup="Admins"
          userDomain="mycompany"
          verifyCert="true"
          debugConnection="false" />

    <!-- ================================================================== -->
    <!-- Jira Integration (optional)                                        -->
    <!-- Enables "File Issue" button on blocking queries                    -->
    <!-- ================================================================== -->
    <jira enabled="false"
          projectId=""
          issueTypeId=""
          queryHashFieldId="" />

    <!-- ================================================================== -->
    <!-- Environment Types                                                  -->
    <!-- deployDDL.php seeds the environment table from this list.           -->
    <!-- Document order determines sort_order (10, 20, 30...) unless        -->
    <!-- explicit sort_order attributes are provided (all-or-nothing).      -->
    <!-- ================================================================== -->
    <environment_types>
        <environment_type name="dev" />
        <environment_type name="test" />
        <environment_type name="qa" />
        <environment_type name="pilot" />
        <environment_type name="staging" />
        <environment_type name="production" default="true" />
    </environment_types>

    <!-- ================================================================== -->
    <!-- Site-wide DB Timeout Defaults (optional)                          -->
    <!-- Fallbacks: 4s connect, 8s read. Override per-host in manageData  -->
    <!-- to tune WAN or heavily-loaded targets individually.               -->
    <!-- ================================================================== -->
    <!-- <timeouts connectTimeout="4" readTimeout="8" /> -->

    <!-- ================================================================== -->
    <!-- Redis Connection Tuning (optional)                                 -->
    <!-- Separate from dbtype enable/disable - these are connection params  -->
    <!-- ================================================================== -->
    <!-- <redis connectTimeout="2" database="0" /> -->

    <!-- ================================================================== -->
    <!-- Feature Toggles                                                    -->
    <!-- enableSpeechAlerts is a global kill switch - leave true and let     -->
    <!-- users mute individually via the browser UI                         -->
    <!-- ================================================================== -->
    <features enableMaintenanceWindows="true"
              dbaSessionTimeout="86400"
              enableSpeechAlerts="true" />

    <!-- ================================================================== -->
    <!-- Test Harness (optional)                                            -->
    <!-- Dedicated test user/database for testAQL.php                       -->
    <!-- ================================================================== -->
    <!-- <testing dbUser="aql_test" dbPass="TestPassword" dbName="aql_test" /> -->

    <!-- ================================================================== -->
    <!-- Database Type Monitoring                                           -->
    <!-- Controls which DB types AQL monitors. mysql is REQUIRED.           -->
    <!-- Monitor user credentials are used by default for all types.        -->
    <!-- Add username/password on a dbtype to override for that type.       -->
    <!-- All monitored HOSTS are in the host table, not here.               -->
    <!-- ================================================================== -->
    <dbtype name="mysql" enabled="true" />
    <dbtype name="innodbcluster" enabled="false" />
    <dbtype name="redis" enabled="false" />
    <dbtype name="mssql" enabled="false" />
    <dbtype name="oracledb" enabled="false" />
    <dbtype name="cassandra" enabled="false" />
    <dbtype name="datastax" enabled="false" />
    <dbtype name="mongodb" enabled="false" />
    <dbtype name="rds" enabled="false" />
    <dbtype name="aurora" enabled="false" />
    <dbtype name="postgresql" enabled="false" username="aql_mon" password="SomethingComplicated" />
</config>
